# ================================================================
# CONFIGURAÇÕES DO DISCORD
# ================================================================

# Webhook do Discord (para alertas automáticos)
# Para criar um webhook:
# 1. Acesse as configurações do seu servidor Discord
# 2. Vá em "Integrações" > "Webhooks"
# 3. Clique em "Novo Webhook"
# 4. Configure o nome e canal
# 5. Copie a URL do webhook e cole abaixo
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/SEU_ID/SEU_TOKEN

# Bot Discord (para responder comandos)
# Para criar um bot:
# 1. Acesse https://discord.com/developers/applications
# 2. Crie uma nova Application
# 3. Vá em "Bot" e clique em "Add Bot"
# 4. Copie o Token
# 5. Em "Privileged Gateway Intents", ative "Message Content Intent"
# 6. Cole o token abaixo
DISCORD_BOT_TOKEN=seu_token_do_bot_aqui

# ================================================================
# CONFIGURAÇÕES DE BANCO DE DADOS
# ================================================================

# Caminho do banco SQLite (padrão: data/precos_cripto.db)
# Use apenas se quiser mudar o local padrão
# DATABASE_PATH=data/precos_cripto.db

# Se migrar para PostgreSQL/MySQL no futuro, use estas variáveis:
# DATABASE_TYPE=sqlite  # Opções: sqlite, postgresql, mysql
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_NAME=coleta_financeira
# DATABASE_USER=seu_usuario
# DATABASE_PASSWORD=sua_senha_segura

# ================================================================
# CONFIGURAÇÕES DE APIs EXTERNAS
# ================================================================

# APIs de Criptomoedas (se precisar de APIs que exigem autenticação)
# COINBASE_API_KEY=sua_chave_api_coinbase
# COINBASE_API_SECRET=seu_secret_coinbase
# BINANCE_API_KEY=sua_chave_api_binance
# BINANCE_API_SECRET=seu_secret_binance
# CRYPTOCOMPARE_API_KEY=sua_chave_api_cryptocompare

# ================================================================
# CONFIGURAÇÕES DE EMAIL (para notificações)
# ================================================================

# Se quiser adicionar notificações por email no futuro
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
# EMAIL_FROM=seu_email@gmail.com
# EMAIL_PASSWORD=sua_senha_ou_app_password
# EMAIL_TO=destinatario@email.com

# ================================================================
# CONFIGURAÇÕES DE AMBIENTE
# ================================================================

# Ambiente de execução (development, production, testing)
# ENVIRONMENT=development

# Modo de debug (true/false)
# DEBUG=false

# Nível de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=INFO

# ================================================================
# CONFIGURAÇÕES DE SEGURANÇA
# ================================================================

# Chave secreta para criptografia de dados sensíveis
# SECRET_KEY=gere_uma_chave_aleatoria_segura_aqui

# Salt para hash de dados
# SECURITY_SALT=gere_um_salt_aleatorio_seguro_aqui

# ================================================================
# CONFIGURAÇÕES DE SERVIÇOS EXTERNOS
# ================================================================

# Sentry (monitoramento de erros)
# SENTRY_DSN=https://sua_chave@sentry.io/seu_projeto

# Google Analytics ou similar
# ANALYTICS_ID=UA-XXXXXXXXX-X

# ================================================================
# CONFIGURAÇÕES DO STREAMLIT
# ================================================================

# Porta do servidor Streamlit (padrão: 8501)
# STREAMLIT_PORT=8501

# Endereço do servidor (padrão: 0.0.0.0)
# STREAMLIT_ADDRESS=0.0.0.0

# Secrets do Streamlit (para funcionalidades avançadas)
# STREAMLIT_SECRET_KEY=sua_chave_secreta_streamlit
